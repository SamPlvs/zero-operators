{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Zero Operators",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#D87A57",
    "light": "#EBA68A",
    "dark": "#C45F3D",

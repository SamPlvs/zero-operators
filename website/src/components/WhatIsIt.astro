---
---

<section id="what" data-animate>
  <div class="container what-grid">
    <div class="what-text">
      <div class="section-label">WHAT IS THIS</div>
      <h2>Autonomous Research &amp; Engineering</h2>
      <p>
        Zero Operators is an autonomous AI research and engineering team. You give it a project — a GitHub repo, some source documents, and success criteria — and it builds, trains, validates, and delivers.
      </p>
      <p>
        A coordinated team of 20 AI agents handles the full ML lifecycle: data engineering, model building, oracle validation, code review, testing, and explainability. You stay in the loop at human checkpoints. ZO remembers everything across sessions. It learns from its mistakes. And the delivery repo stays clean.
      </p>
    </div>
    <div class="what-visual" aria-hidden="true">
      <svg viewBox="0 0 420 220" fill="none" xmlns="http://www.w3.org/2000/svg" class="workflow-svg">
        <!-- Background grid -->
        <defs>
          <pattern id="wf-grid" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="20" height="20" fill="none"/>
            <circle cx="10" cy="10" r="0.3" fill="currentColor" opacity="0.08"/>
          </pattern>
        </defs>
        <rect width="420" height="220" fill="url(#wf-grid)"/>

        <!-- ═══ NODE 1: plan.md ═══ -->
        <g class="wf-node">
          <!-- Outer ring (dashed) -->
          <circle cx="70" cy="90" r="36" stroke="currentColor" stroke-width="0.8" stroke-dasharray="4 3" fill="none" opacity="0.25"/>
          <!-- Inner ring (solid) -->
          <circle cx="70" cy="90" r="26" stroke="currentColor" stroke-width="1" fill="none" opacity="0.45"/>
          <!-- Halo glow -->
          <circle cx="70" cy="90" r="20" fill="currentColor" opacity="0.04"/>
          <!-- Center dot -->
          <circle cx="70" cy="90" r="3" fill="currentColor" opacity="0.7"/>
          <!-- Cardinal ticks on outer ring -->
          <line x1="70" y1="52" x2="70" y2="57" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="70" y1="123" x2="70" y2="128" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="32" y1="90" x2="37" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="103" y1="90" x2="108" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <!-- Document icon -->
          <rect x="60" y="79" width="14" height="18" rx="1.5" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.6"/>
          <line x1="64" y1="86" x2="70" y2="86" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
          <line x1="64" y1="89" x2="72" y2="89" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
          <line x1="64" y1="92" x2="69" y2="92" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
          <!-- Folded corner -->
          <polyline points="69,79 69,83 74,83" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.4"/>
        </g>
        <!-- Label -->
        <text x="70" y="145" text-anchor="middle" fill="currentColor" font-family="'Share Tech Mono', monospace" font-size="11" opacity="0.9" letter-spacing="0.05em">plan.md</text>

        <!-- ═══ CONNECTION 1: plan.md → Agent Team ═══ -->
        <line x1="112" y1="90" x2="168" y2="90" stroke="currentColor" stroke-width="0.8" stroke-dasharray="6 4" opacity="0.3"/>
        <!-- Animated flow dots -->
        <circle r="2" fill="currentColor" opacity="0.8" class="flow-dot flow-dot-1">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M112,0 L168,0" begin="0s"/>
        </circle>
        <circle r="1.5" fill="currentColor" opacity="0.5" class="flow-dot flow-dot-2">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M112,0 L168,0" begin="0.8s"/>
        </circle>
        <circle r="1" fill="currentColor" opacity="0.35" class="flow-dot flow-dot-3">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M112,0 L168,0" begin="1.6s"/>
        </circle>
        <!-- Arrowhead -->
        <polygon points="170,90 164,86 164,94" fill="currentColor" opacity="0.5"/>

        <!-- ═══ NODE 2: Agent Team ═══ -->
        <g class="wf-node">
          <!-- Outer ring (solid) -->
          <circle cx="210" cy="90" r="40" stroke="currentColor" stroke-width="1" fill="none" opacity="0.35"/>
          <!-- Middle ring (dashed) -->
          <circle cx="210" cy="90" r="30" stroke="currentColor" stroke-width="0.8" stroke-dasharray="3 4" fill="none" opacity="0.2"/>
          <!-- Inner ring (solid) -->
          <circle cx="210" cy="90" r="20" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.55"/>
          <!-- Halo glow -->
          <circle cx="210" cy="90" r="14" fill="currentColor" opacity="0.05"/>
          <!-- Center dot -->
          <circle cx="210" cy="90" r="3.5" fill="currentColor" opacity="0.8"/>
          <!-- Cardinal ticks on outer ring -->
          <line x1="210" y1="47" x2="210" y2="53" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="210" y1="127" x2="210" y2="133" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="167" y1="90" x2="173" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="247" y1="90" x2="253" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <!-- Orbiting agent dots -->
          <circle cx="210" cy="60" r="2.5" fill="currentColor" opacity="0.6">
            <animateTransform attributeName="transform" type="rotate" from="0 210 90" to="360 210 90" dur="12s" repeatCount="indefinite"/>
          </circle>
          <circle cx="240" cy="90" r="2" fill="currentColor" opacity="0.45">
            <animateTransform attributeName="transform" type="rotate" from="120 210 90" to="480 210 90" dur="15s" repeatCount="indefinite"/>
          </circle>
          <circle cx="195" cy="118" r="2" fill="currentColor" opacity="0.5">
            <animateTransform attributeName="transform" type="rotate" from="240 210 90" to="600 210 90" dur="10s" repeatCount="indefinite"/>
          </circle>
          <circle cx="225" cy="118" r="1.5" fill="currentColor" opacity="0.35">
            <animateTransform attributeName="transform" type="rotate" from="60 210 90" to="420 210 90" dur="18s" repeatCount="indefinite"/>
          </circle>
          <circle cx="180" cy="85" r="1.5" fill="currentColor" opacity="0.3">
            <animateTransform attributeName="transform" type="rotate" from="180 210 90" to="540 210 90" dur="14s" repeatCount="indefinite"/>
          </circle>
        </g>
        <!-- Label -->
        <text x="210" y="148" text-anchor="middle" fill="currentColor" font-family="'Share Tech Mono', monospace" font-size="11" opacity="0.9" letter-spacing="0.05em">Agent Team</text>

        <!-- ═══ CONNECTION 2: Agent Team → Delivery Repo ═══ -->
        <line x1="252" y1="90" x2="308" y2="90" stroke="currentColor" stroke-width="0.8" stroke-dasharray="6 4" opacity="0.3"/>
        <!-- Animated flow dots -->
        <circle r="2" fill="currentColor" opacity="0.8" class="flow-dot">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M252,0 L308,0" begin="0.3s"/>
        </circle>
        <circle r="1.5" fill="currentColor" opacity="0.5" class="flow-dot">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M252,0 L308,0" begin="1.1s"/>
        </circle>
        <circle r="1" fill="currentColor" opacity="0.35" class="flow-dot">
          <animateMotion dur="2.5s" repeatCount="indefinite" path="M252,0 L308,0" begin="1.9s"/>
        </circle>
        <!-- Arrowhead -->
        <polygon points="310,90 304,86 304,94" fill="currentColor" opacity="0.5"/>

        <!-- ═══ NODE 3: Delivery Repo ═══ -->
        <g class="wf-node">
          <!-- Outer ring (dashed) -->
          <circle cx="350" cy="90" r="36" stroke="currentColor" stroke-width="0.8" stroke-dasharray="4 3" fill="none" opacity="0.25"/>
          <!-- Inner ring (solid) -->
          <circle cx="350" cy="90" r="26" stroke="currentColor" stroke-width="1" fill="none" opacity="0.45"/>
          <!-- Halo glow -->
          <circle cx="350" cy="90" r="20" fill="currentColor" opacity="0.04"/>
          <!-- Center dot -->
          <circle cx="350" cy="90" r="3" fill="currentColor" opacity="0.7"/>
          <!-- Cardinal ticks on outer ring -->
          <line x1="350" y1="52" x2="350" y2="57" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="350" y1="123" x2="350" y2="128" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="312" y1="90" x2="317" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <line x1="383" y1="90" x2="388" y2="90" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
          <!-- Checkmark icon -->
          <polyline points="340,90 347,97 362,82" stroke="var(--success, #40c040)" stroke-width="1.8" fill="none" opacity="0.7" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
        <!-- Label -->
        <text x="350" y="145" text-anchor="middle" fill="currentColor" font-family="'Share Tech Mono', monospace" font-size="11" opacity="0.9" letter-spacing="0.05em">Delivery Repo</text>

        <!-- Subtle horizontal baseline -->
        <line x1="30" y1="160" x2="390" y2="160" stroke="currentColor" stroke-width="0.3" opacity="0.08"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .what-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .what-text p {
    opacity: 0.8;
    line-height: 1.8;
  }

  .what-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--orbital-color, var(--amber));
  }

  .what-visual svg {
    width: 100%;
    max-width: 420px;
  }

  .workflow-svg .flow-dot {
    filter: blur(0.3px);
  }

  .workflow-svg .wf-node {
    transition: opacity 0.4s ease;
  }

  @media (max-width: 768px) {
    .what-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .what-visual {
      order: -1;
    }
  }
</style>

---
---

<section class="hero">
  <div class="orbital-field" aria-hidden="true">
    <!-- ZO-05 Orbital + Grid Hybrid -->
    <svg class="hero-bg" viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice">
      <rect width="800" height="450" fill="transparent"/>
      <!-- Fine grid -->
      <defs>
        <pattern id="hero-grid" width="24" height="24" patternUnits="userSpaceOnUse">
          <path d="M24 0L0 0 0 24" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.22" opacity="0.1"/>
        </pattern>
      </defs>
      <rect width="800" height="450" fill="url(#hero-grid)"/>
      <!-- Orbital at center -->
      <g transform="translate(400, 225)">
        <circle r="40" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.5" opacity="0.45"/>
        <circle r="80" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.4" opacity="0.35"/>
        <circle r="130" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.4" opacity="0.28"/>
        <circle r="190" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.35" opacity="0.2"/>
        <circle r="260" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.14"/>
        <circle r="340" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.1"/>
        <!-- Dashed rings -->
        <circle r="60" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.4" stroke-dasharray="2 6" opacity="0.25"/>
        <circle r="110" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.35" stroke-dasharray="2 8" opacity="0.2"/>
        <circle r="160" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" stroke-dasharray="3 10" opacity="0.15"/>
        <!-- Cardinal ticks -->
        <line x1="0" y1="-260" x2="0" y2="-248" stroke="var(--orbital-color, #F0C040)" stroke-width="0.8" opacity="0.4"/>
        <line x1="0" y1="260" x2="0" y2="248" stroke="var(--orbital-color, #F0C040)" stroke-width="0.8" opacity="0.4"/>
        <line x1="-260" y1="0" x2="-248" y2="0" stroke="var(--orbital-color, #F0C040)" stroke-width="0.8" opacity="0.4"/>
        <line x1="260" y1="0" x2="248" y2="0" stroke="var(--orbital-color, #F0C040)" stroke-width="0.8" opacity="0.4"/>
        <!-- Diagonal ticks -->
        <line x1="184" y1="-184" x2="176" y2="-176" stroke="var(--orbital-color, #F0C040)" stroke-width="0.6" opacity="0.3"/>
        <line x1="-184" y1="-184" x2="-176" y2="-176" stroke="var(--orbital-color, #F0C040)" stroke-width="0.6" opacity="0.3"/>
        <line x1="184" y1="184" x2="176" y2="176" stroke="var(--orbital-color, #F0C040)" stroke-width="0.6" opacity="0.3"/>
        <line x1="-184" y1="184" x2="-176" y2="176" stroke="var(--orbital-color, #F0C040)" stroke-width="0.6" opacity="0.3"/>
        <!-- Radial lines -->
        <line x1="0" y1="-20" x2="0" y2="-400" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.06"/>
        <line x1="0" y1="20" x2="0" y2="400" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.06"/>
        <line x1="-20" y1="0" x2="-400" y2="0" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.06"/>
        <line x1="20" y1="0" x2="400" y2="0" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.06"/>
        <!-- Center node -->
        <circle r="4" fill="var(--orbital-color, #F0C040)" opacity="0.8"/>
        <circle r="8" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.5" opacity="0.4"/>
        <circle r="14" fill="none" stroke="var(--orbital-color, #F0C040)" stroke-width="0.3" opacity="0.2"/>
        <!-- Orbiting dots -->
        <circle cx="190" cy="0" r="3" fill="var(--orbital-color, #F0C040)" opacity="0.6"/>
        <circle cx="-130" cy="-90" r="2" fill="var(--orbital-color, #F0C040)" opacity="0.4"/>
        <circle cx="50" cy="-80" r="1.5" fill="var(--orbital-color, #F0C040)" opacity="0.35"/>
        <circle cx="-60" cy="110" r="2.5" fill="var(--orbital-color, #F0C040)" opacity="0.45"/>
      </g>
    </svg>
  </div>

  <div class="hero-content">
    <h1 class="hero-animate">ZERO OPERATORS</h1>
    <span class="subtitle hero-animate hero-animate-delay-1">AUTONOMOUS AI SYSTEMS</span>
    <p class="tagline hero-animate hero-animate-delay-2">You input a plan. Agents execute. The oracle verifies.</p>
    <div class="hero-actions hero-animate hero-animate-delay-3">
      <a href="#quickstart" class="btn btn-primary">Get Started</a>
      <a href="https://github.com/SamPlvs/zero-operators" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">View on GitHub</a>
    </div>
    <div class="hero-animate hero-animate-delay-4 scroll-indicator-wrap">
      <svg class="scroll-indicator" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex-direction: column;
    overflow: hidden;
  }

  .orbital-field {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .orbital-field svg {
    width: 100%;
    height: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 0 24px;
  }

  h1 {
    text-transform: uppercase;
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 3.5px;
    color: var(--amber-dim);
    text-transform: uppercase;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 14px;
    opacity: 0.7;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 12px;
  }

  .scroll-indicator-wrap {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--amber-dim);
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 260px;
    }
    .hero-actions .btn {
      justify-content: center;
    }
  }
</style>

---
interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 72 72"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-label="Zero Operators orbital mark"
>
  <circle cx="36" cy="36" r="32" stroke="currentColor" stroke-width="1.2"/>
  <circle cx="36" cy="36" r="24" stroke="currentColor" stroke-width="0.6" stroke-dasharray="3 4"/>
  <line x1="12" y1="60" x2="60" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
  <line x1="36" y1="4" x2="36" y2="10" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <line x1="36" y1="62" x2="36" y2="68" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <line x1="4" y1="36" x2="10" y2="36" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <line x1="62" y1="36" x2="68" y2="36" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <circle cx="36" cy="36" r="3" fill="currentColor"/>
</svg>

---
import OrbitalMark from './OrbitalMark.astro';
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo" aria-label="Zero Operators home">
      <OrbitalMark size={28} />
      <span class="logo-text">ZERO OPERATORS</span>
    </a>
    <div class="header-actions">
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle dark/light mode"
        type="button"
      >&#9788;</button>
      <a
        href="https://github.com/SamPlvs/zero-operators"
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795 .945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 56px;
    background: transparent;
    border-bottom: 1px solid var(--rule);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--amber);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--amber-border);
    border-radius: 4px;
    color: var(--amber-dim);
    font-family: var(--font-mono);
    font-size: 16px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    padding: 0;
    line-height: 1;
  }

  .theme-toggle:hover {
    color: var(--amber);
    border-color: var(--amber);
  }

  .github-link {
    color: var(--amber-dim);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .github-link:hover {
    color: var(--amber);
    opacity: 1;
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  const stored = localStorage.getItem('zo-theme');
  if (stored) {
    document.documentElement.setAttribute('data-theme', stored);
    if (toggle) toggle.textContent = stored === 'light' ? '\u25D7' : '\u263C';
  }

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('zo-theme', next);
    toggle.textContent = next === 'light' ? '\u25D7' : '\u263C';
  });
</script>

---
import stats from '../data/stats.json';

const statEntries = [
  { key: 'accuracy', ...stats.accuracy },
  { key: 'cost', ...stats.cost },
  { key: 'tests', ...stats.tests },
  { key: 'agents', ...stats.agents }
];
---

<section id="proof" class="bg-surface" data-animate>
  <div class="container">
    <div class="section-label">VALIDATED</div>
    <h2>Proven end-to-end</h2>
    <p class="subheadline">MNIST digit classifier built autonomously. 5 phases, 4 clean commits, zero human code.</p>

    <div class="stat-grid" data-animate-stagger>
      {statEntries.map((s) => (
        <div class="stat-card">
          <span
            class="stat-number"
            data-count-to={s.value}
            data-count-prefix={s.prefix || ''}
            data-count-suffix={s.suffix || ''}
          >
            {(s.prefix || '') + '0' + (s.suffix || '')}
          </span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 8px;
  }

  .subheadline {
    color: var(--amber-dim);
    font-size: 14px;
    margin-bottom: 48px;
    max-width: 560px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 32px 16px;
    background: var(--surface);
    border: 1px solid var(--amber-border);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .stat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

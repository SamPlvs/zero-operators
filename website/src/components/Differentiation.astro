---
import comparisons from '../data/comparisons.json';

const dimensions = comparisons.differentiation.dimensions;
---

<section id="differentiation" data-animate>
  <div class="container">
    <div class="section-label">DIFFERENTIATION</div>
    <h2>Not another coding assistant</h2>
    <p class="subheadline">Most AI tools help you write code. ZO replaces the need to coordinate it.</p>

    <!-- Desktop table -->
    <div class="diff-table">
      <div class="diff-header">
        <div class="diff-cell diff-dim">Dimension</div>
        <div class="diff-cell diff-dim">
          Coding Assistants
          <span class="diff-sub">(Cursor, Copilot)</span>
        </div>
        <div class="diff-cell diff-dim">
          Agent Frameworks
          <span class="diff-sub">(CrewAI, AutoGen)</span>
        </div>
        <div class="diff-cell diff-zo">
          Zero Operators
        </div>
      </div>
      <div class="diff-body" data-animate-stagger>
        {dimensions.map((d) => (
          <div class="diff-row">
            <div class="diff-cell diff-dim">{d.label}</div>
            <div class="diff-cell diff-dim">{d.assistants}</div>
            <div class="diff-cell diff-dim">{d.frameworks}</div>
            <div class="diff-cell diff-zo">{d.zo}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="diff-cards" data-animate-stagger>
      {dimensions.map((d) => (
        <div class="card diff-card">
          <h3 class="diff-card-label">{d.label}</h3>
          <div class="diff-card-row">
            <span class="diff-card-key">Assistants</span>
            <span class="diff-card-val diff-dim">{d.assistants}</span>
          </div>
          <div class="diff-card-row">
            <span class="diff-card-key">Frameworks</span>
            <span class="diff-card-val diff-dim">{d.frameworks}</span>
          </div>
          <div class="diff-card-row diff-card-row--zo">
            <span class="diff-card-key">Zero Operators</span>
            <span class="diff-card-val diff-zo">{d.zo}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="diff-closing" data-animate>
      Coding assistants help you write lines. Agent frameworks help you chain tasks. ZO gives you a team that owns the project end-to-end.
    </p>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 8px;
  }

  .subheadline {
    color: var(--amber-dim);
    font-size: 14px;
    margin-bottom: 48px;
    max-width: 520px;
  }

  /* Desktop table */
  .diff-table {
    width: 100%;
    border: 1px solid var(--amber-border);
  }

  .diff-header {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1.2fr 1.4fr;
    border-bottom: 1px solid var(--amber-border);
  }

  .diff-header .diff-cell {
    padding: 16px 20px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .diff-sub {
    display: block;
    font-weight: 400;
    font-size: 11px;
    opacity: 0.5;
    margin-top: 2px;
  }

  .diff-body .diff-row {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1.2fr 1.4fr;
    border-bottom: 1px solid var(--rule);
  }

  .diff-body .diff-row:last-child {
    border-bottom: none;
  }

  .diff-cell {
    padding: 12px 20px;
    font-size: 13px;
    line-height: 1.5;
  }

  .diff-dim {
    color: var(--amber-dim);
  }

  .diff-zo {
    color: var(--amber);
    font-weight: 700;
    border-left: 2px solid var(--amber);
  }

  /* Mobile cards — hidden on desktop */
  .diff-cards {
    display: none;
  }

  .diff-card {
    padding: 20px;
    margin-bottom: 12px;
  }

  .diff-card-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 15px;
    color: var(--amber);
    margin-bottom: 12px;
  }

  .diff-card-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 12px;
  }

  .diff-card-row:last-child {
    border-bottom: none;
  }

  .diff-card-row--zo {
    border-left: 2px solid var(--amber);
    padding-left: 12px;
    margin-left: -12px;
  }

  .diff-card-key {
    color: var(--amber-dim);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
    margin-right: 12px;
  }

  .diff-card-val {
    text-align: right;
  }

  .diff-closing {
    color: var(--amber-dim);
    font-size: 13px;
    margin-top: 40px;
    max-width: 640px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .diff-table {
      display: none;
    }

    .diff-cards {
      display: flex;
      flex-direction: column;
    }
  }
</style>

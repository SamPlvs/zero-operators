---
import OrbitalMark from './OrbitalMark.astro';
---

<footer class="site-footer">
  <div class="footer-inner">
    <OrbitalMark size={36} />
    <span class="footer-title">ZERO OPERATORS</span>
    <span class="footer-version">v1.0.1 — validated</span>
    <nav class="footer-links">
      <a href="https://github.com/SamPlvs/zero-operators" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep">&middot;</span>
      <a href="https://github.com/SamPlvs/zero-operators/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a>
    </nav>

    <div class="footer-creator">
      <span class="creator-label">Created by</span>
      <a href="https://samtukra.com" target="_blank" rel="noopener noreferrer" class="creator-name">Samyakh (Sam) Tukra</a>
      <nav class="creator-socials">
        <a href="https://www.linkedin.com/in/samyakhtukra/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://x.com/SamTukra" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://samtukra.com" target="_blank" rel="noopener noreferrer" aria-label="Website">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </a>
      </nav>
    </div>

    <span class="footer-copy">&copy; 2026 Samyakh Tukra</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding: 60px 24px 40px;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .footer-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.14em;
    color: var(--amber);
  }

  .footer-version {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--amber-dim);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .footer-links a {
    color: var(--amber-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--amber);
  }

  .footer-sep {
    color: var(--amber-dim);
    opacity: 0.4;
  }

  .footer-creator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
    width: 100%;
    max-width: 320px;
  }

  .creator-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber-dim);
    opacity: 0.6;
  }

  .creator-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.06em;
    color: var(--amber);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .creator-name:hover {
    opacity: 0.8;
  }

  .creator-socials {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .creator-socials a {
    color: var(--amber-dim);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .creator-socials a:hover {
    color: var(--amber);
    opacity: 1;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--amber-dim);
    opacity: 0.6;
    margin-top: 4px;
  }
</style>

---
import pipeline from '../data/pipeline.json';
---

<section id="pipeline" class="bg-grid" data-animate>
  <div class="container">
    <div class="section-label">THE PIPELINE</div>
    <h2>From data to delivery</h2>
    <p class="pipeline-sub">Six phases. Gated at every transition. Oracle-validated.</p>

    <div class="pipeline-track" data-scroll-drive>
      <div class="pipeline-spine" aria-hidden="true"></div>
      {pipeline.map((phase, i) => (
        <>
          {i > 0 && <div class="connector" aria-hidden="true"></div>}
          <div class="phase-node">
            <div class="phase-header">
              <div class="phase-num-wrap">
                <svg class="phase-orbital" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="22" cy="22" r="20" stroke="var(--amber)" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.3"/>
                  <circle cx="22" cy="22" r="14" stroke="var(--amber)" stroke-width="0.8" opacity="0.5"/>
                  <circle cx="22" cy="22" r="2" fill="var(--amber)" opacity="0.6"/>
                </svg>
                <span class="phase-num">{String(phase.phase).padStart(2, '0')}</span>
              </div>
              <div class="phase-info">
                <h3>{phase.name}</h3>
                <p class="phase-desc">{phase.description}</p>
                <div class="phase-agents">
                  {phase.agents.map((agent: string) => {
                    const tier = agent === 'Oracle / QA' || agent === 'Model Builder' ? 'badge-opus'
                      : agent === 'Code Reviewer' || agent === 'Test Engineer' || agent === 'XAI Agent' || agent === 'ML Engineer' ? 'badge-sonnet'
                      : 'badge-haiku';
                    return <span class={`badge ${tier}`}>{agent}</span>;
                  })}
                </div>
              </div>
            </div>
            <div class="phase-gate">
              {phase.gate === 'blocking' ? (
                <span class="gate-icon gate-icon--human" aria-hidden="true">
                  <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="9" stroke="var(--amber)" stroke-width="1" opacity="0.4" class="gate-pulse-ring"/>
                    <polygon points="11,4 15,11 11,18 7,11" fill="var(--amber)" opacity="0.8"/>
                  </svg>
                </span>
              ) : (
                <span class="gate-icon gate-icon--auto" aria-hidden="true">
                  <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="9" stroke="var(--amber-dim)" stroke-width="1" opacity="0.4"/>
                    <polyline points="7,11 10,14 15,8" stroke="var(--amber-dim)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              )}
              <span class="gate-label">{phase.gate === 'blocking' ? 'HUMAN GATE' : 'AUTO GATE'}</span>
            </div>
            {phase.hasLoop && (
              <div class="loop-indicator">
                <svg class="loop-arrow-svg" viewBox="0 0 80 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M10,40 C10,8 70,8 70,40" stroke="var(--amber)" stroke-width="1.2" fill="none" stroke-dasharray="4 3" opacity="0.5"/>
                  <polygon points="70,40 66,34 74,34" fill="var(--amber)" opacity="0.6"/>
                </svg>
                <span class="loop-label">iterate until oracle passes</span>
              </div>
            )}
          </div>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding-top: var(--section-gap);
    padding-bottom: calc(var(--section-gap) * 0.5);
  }

  .pipeline-sub {
    color: var(--amber-dim);
    margin-bottom: 56px;
  }

  .pipeline-track {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    max-width: 640px;
    margin: 0 auto;
    padding: 40px 0 120px;
    position: relative;
  }

  /* Vertical dashed spine behind all cards */
  .pipeline-spine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: repeating-linear-gradient(
      to bottom,
      var(--amber-border) 0px,
      var(--amber-border) 6px,
      transparent 6px,
      transparent 12px
    );
    opacity: 0.4;
    z-index: 0;
  }

  .connector {
    width: 2px;
    height: 48px;
    background: var(--amber-border);
    margin: 0 auto;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .phase-node {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 24px;
    position: relative;
    z-index: 1;
  }

  .phase-header {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .phase-num-wrap {
    position: relative;
    flex-shrink: 0;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phase-orbital {
    position: absolute;
    width: 44px;
    height: 44px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .phase-num {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 36px;
    line-height: 1;
    color: var(--amber);
    flex-shrink: 0;
    min-width: 52px;
    opacity: 0.4;
    transition: opacity 0.5s ease;
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .phase-node.active .phase-num {
    opacity: 1;
  }

  .phase-node.active .phase-orbital {
    opacity: 1;
  }

  .phase-info {
    flex: 1;
    min-width: 0;
  }

  .phase-info h3 {
    margin-bottom: 8px;
  }

  .phase-desc {
    font-size: 13px;
    color: var(--amber-dim);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .phase-agents {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .phase-gate {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }

  .gate-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .gate-icon svg {
    width: 22px;
    height: 22px;
  }

  .gate-icon--human .gate-pulse-ring {
    animation: gatePulse 2s ease-in-out infinite;
  }

  @keyframes gatePulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.7; }
  }

  .gate-label {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber-dim);
  }

  .gate-icon--human + .gate-label {
    color: var(--amber);
  }

  .loop-indicator {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-left: 72px;
  }

  .loop-arrow-svg {
    width: 60px;
    height: 36px;
    flex-shrink: 0;
  }

  .loop-label {
    font-size: 11px;
    color: var(--amber);
    font-style: italic;
    font-family: var(--font-mono);
  }

  @media (max-width: 640px) {
    .phase-header {
      flex-direction: column;
      gap: 8px;
    }

    .phase-num {
      font-size: 28px;
      min-width: auto;
    }

    .loop-indicator {
      padding-left: 0;
    }
  }
</style>
